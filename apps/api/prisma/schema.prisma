generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("COLLECTOR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coins     Coin[]
}

model Coin {
  id          String   @id @default(uuid())
  title       String
  description String?
  metal       String?
  imageUrl    String?
  status      String   @default("DRAFT")
  grade       String?
  valuation   String?
  expertName  String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
